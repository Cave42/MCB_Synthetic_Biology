  title = {Within-{{Host Rhinovirus Evolution}} in {{Upper}} and {{Lower Respiratory Tract Highlights Capsid Variability}} and {{Mutation-Independent Compartmentalization}}},
  author = {Makhsous, Negar and Goya, Stephanie and Avenda{\~n}o, Carlos C and Rupp, Jason and Kuypers, Jane and Jerome, Keith R and Boeckh, Michael and Waghmare, Alpana and Greninger, Alexander L},
  year = 2024,
